{
  "name": "Zeno website - Async Polling Engine",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "compile-figma",
        "responseCode": 202,
        "options": {}
      },
      "id": "c5dbb02f-cf06-4a6a-8da8-da877acd345c",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
