        -8640,
        2224
      ],
      "webhookId": "a3558b29-aac4-4433-8682-4320a0bde63c"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\n\n// Safely extract regardless of payload structure\nconst figmaUrl = body.figmaUrl || body.url;\nconst format = body.format || body.outputFormat || 'react';\nconst figmaToken = body.figmaToken;\nconst jobId = body.jobId;\n\nif (!figmaUrl) {\n    throw new Error(\"Missing Figma URL in request payload.\");\n}\nif (!figmaToken) {\n    throw new Error(\"Missing Figma Token in request payload. Check your Node backend forwarding.\");\n}\nif (!jobId) {\n    throw new Error(\"Missing jobId in request payload. Your backend must send a jobId.\");\n}\n\n// --- Parse the URL ---\nconst fileIdMatch = figmaUrl.match(/\\/(?:file|design)\\/([a-zA-Z0-9]+)/);\nconst fileId = fileIdMatch ? fileIdMatch[1] : null;\n\nconst nodeIdMatch = figmaUrl.match(/node-id=([a-zA-Z0-9\\-%]+)/);\nlet nodeId = nodeIdMatch ? nodeIdMatch[1] : null;\n\nif (nodeId) {\n    nodeId = decodeURIComponent(nodeId).replace(/-/g, ':');\n}\n\nif (!fileId || !nodeId) {\n    throw new Error(\"Could not extract File ID or Node ID from URL.\");\n}\n\nreturn [{ json: { figmaUrl, fileId, nodeId, format, figmaToken, jobId } }];"
      },
      "id": "109a22a0-6001-4c13-9e78-ce169f85550d",
      "name": "Input & Parse Figma URL",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -8448,
        2224
      ]
    },
    {
      "parameters": {
        "url": "={{'https://api.figma.com/v1/files/' + $json.fileId + '/nodes?ids=' + $json.nodeId}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Figma-Token",
              "value": "={{ $('Input & Parse Figma URL').first().json.figmaToken }}"
            }
          ]
        },
        "options": {}
      },
      "id": "25c4b0c3-993a-4617-9f22-115ba6958573",
      "name": "Figma API Request (Layout)",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -8224,
        2224
      ]
    },
    {
      "parameters": {
        "jsCode": "const nodeId = $('Input & Parse Figma URL').first().json.nodeId;\nconst figmaData = $('Figma API Request (Layout)').first().json.nodes[nodeId].document;\nlet targetIds = [];\n\nfunction extractIds(node) {\n  if (!node || node.visible === false) return;\n\n  const isImage = node.fills && node.fills.some(f => f.type === 'IMAGE' && f.visible !== false);\n  if (isImage) {\n      targetIds.push(node.id);\n      return;\n  }\n\n  function hasTextDeep(n) {\n      if (!n || n.visible === false) return false;\n      if (n.type === 'TEXT') return true;\n      if (n.children) return n.children.some(hasTextDeep);\n      return false;\n  }\n  function hasVectorDeep(n) {\n      if (!n || n.visible === false) return false;\n      if (['VECTOR', 'BOOLEAN_OPERATION', 'STAR', 'POLYGON', 'ELLIPSE'].includes(n.type)) return true;\n      if (n.children) return n.children.some(hasVectorDeep);\n      return false;\n  }\n\n  const isContainer = ['FRAME', 'GROUP', 'INSTANCE', 'COMPONENT'].includes(node.type);\n  if (isContainer) {\n      if (hasVectorDeep(node) && !hasTextDeep(node)) {\n          targetIds.push(node.id);\n          return;\n      }\n  }\n\n  const isVector = ['VECTOR', 'BOOLEAN_OPERATION', 'STAR', 'POLYGON', 'ELLIPSE'].includes(node.type);\n  if (isVector) {\n      targetIds.push(node.id);\n      return;\n  }\n\n  if (node.children) node.children.forEach(extractIds);\n}\n\nextractIds(figmaData);\ntargetIds = [...new Set(targetIds)];\nreturn [{ json: { idsToFetch: targetIds.join(',') } }];"
      },
      "id": "9e20e43f-965f-4deb-9387-03be965dc9cc",
      "name": "ID Extractor",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -8016,
        2224
      ]
    },
    {
      "parameters": {
        "url": "={{'https://api.figma.com/v1/images/' + $('Input & Parse Figma URL').first().json.fileId + '?ids=' + $json.idsToFetch + '&format=svg'}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Figma-Token",
              "value": "={{ $('Input & Parse Figma URL').first().json.figmaToken }}"
            }
          ]
        },
        "options": {}
      },
      "id": "0554a6b6-6da8-4b15-996b-d991495d1d59",
      "name": "Figma Image Fetcher",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        -7824,
        2224
      ]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
